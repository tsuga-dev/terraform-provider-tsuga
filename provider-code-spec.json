{
  "datasources": [
    {
      "name": "team",
      "schema": {
        "attributes": [
          {
            "name": "id",
            "string": {
              "computed_optional_required": "computed_optional",
              "description": "Identifier of the team to retrieve. Use the `id` returned by team list or create responses.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.LengthBetween(1, 250)"
                  }
                }
              ]
            }
          },
          {
            "name": "description",
            "string": {
              "computed_optional_required": "computed",
              "description": "Optional team description supplied by a user."
            }
          },
          {
            "name": "name",
            "string": {
              "computed_optional_required": "computed_optional",
              "description": "Human-readable team name displayed throughout Tsuga and used in team search."
            }
          },
          {
            "name": "tags",
            "list_nested": {
              "computed_optional_required": "computed",
              "nested_object": {
                "attributes": [
                  {
                    "name": "key",
                    "string": {
                      "computed_optional_required": "computed",
                      "description": "Tag key attached to the resource. Consumers can use key/value tags for filtering, ownership context, and policy checks."
                    }
                  },
                  {
                    "name": "value",
                    "string": {
                      "computed_optional_required": "computed",
                      "description": "Tag value attached to the resource for this key. Tsuga returns the value exactly as stored."
                    }
                  }
                ]
              },
              "description": "Key/value tags applied to the resource. Use them to organize resources and to satisfy tag policies."
            }
          },
          {
            "name": "visibility",
            "string": {
              "computed_optional_required": "computed",
              "description": "`public` makes team-owned resources discoverable according to access controls. `private` restricts discovery to team members and authorized users."
            }
          }
        ]
      }
    },
    {
      "name": "user",
      "schema": {
        "attributes": [
          {
            "name": "id",
            "string": {
              "computed_optional_required": "required",
              "description": "Identifier of the organization user to retrieve. Use the `id` returned by list users responses.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.LengthBetween(1, 250)"
                  }
                }
              ]
            }
          },
          {
            "name": "email",
            "string": {
              "computed_optional_required": "computed",
              "description": "Lowercase email address for the user. Use this for display and invitation matching, not as a stable identifier."
            }
          },
          {
            "name": "name",
            "string": {
              "computed_optional_required": "computed",
              "description": "Display name of the user."
            }
          },
          {
            "name": "role",
            "string": {
              "computed_optional_required": "computed",
              "description": "Organization role for the user: `admin`, `public_editor`, `public_viewer`, or `teams_only`."
            }
          }
        ]
      }
    }
  ],
  "provider": {
    "name": "tsuga"
  },
  "resources": [
    {
      "name": "custom_usage_tag",
      "schema": {
        "attributes": [
          {
            "name": "tag_key",
            "string": {
              "computed_optional_required": "required",
              "description": "Telemetry tag key to track as a custom usage dimension. The key must be unique within the organization.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.LengthBetween(1, 250)"
                  }
                }
              ],
              "plan_modifiers": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework/resource/schema/stringplanmodifier"
                      }
                    ],
                    "schema_definition": "stringplanmodifier.RequiresReplace()"
                  }
                }
              ]
            }
          },
          {
            "name": "id",
            "string": {
              "computed_optional_required": "computed",
              "description": "Unique identifier of the custom usage tag. Generated by Tsuga."
            }
          }
        ]
      }
    },
    {
      "name": "ingestion_api_key",
      "schema": {
        "attributes": [
          {
            "name": "name",
            "string": {
              "computed_optional_required": "required",
              "description": "Kebab-case name for the ingestion API key. Maximum length is 100 characters.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.LengthBetween(1, 100)"
                  }
                }
              ]
            }
          },
          {
            "name": "owner",
            "string": {
              "computed_optional_required": "required",
              "description": "Team ID that will own and manage the ingestion API key.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.LengthBetween(1, 250)"
                  }
                }
              ]
            }
          },
          {
            "name": "tags",
            "list_nested": {
              "computed_optional_required": "required",
              "nested_object": {
                "attributes": [
                  {
                    "name": "key",
                    "string": {
                      "computed_optional_required": "required",
                      "description": "Tag key to attach to the resource. Maximum length is 128 characters.",
                      "validators": [
                        {
                          "custom": {
                            "imports": [
                              {
                                "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                              }
                            ],
                            "schema_definition": "stringvalidator.LengthAtMost(128)"
                          }
                        }
                      ]
                    }
                  },
                  {
                    "name": "value",
                    "string": {
                      "computed_optional_required": "required",
                      "description": "Tag value to attach to the resource. Maximum length is 256 characters and leading or trailing whitespace is rejected.",
                      "validators": [
                        {
                          "custom": {
                            "imports": [
                              {
                                "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                              }
                            ],
                            "schema_definition": "stringvalidator.LengthAtMost(256)"
                          }
                        },
                        {
                          "custom": {
                            "imports": [
                              {
                                "path": "regexp"
                              },
                              {
                                "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                              }
                            ],
                            "schema_definition": "stringvalidator.RegexMatches(regexp.MustCompile(\"^\\\\S(.*\\\\S)?$\"), \"\")"
                          }
                        }
                      ]
                    }
                  }
                ]
              },
              "description": "Key/value tags to apply to the resource. Up to 50 tags are accepted and tag policies may require specific keys or values.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/listvalidator"
                      }
                    ],
                    "schema_definition": "listvalidator.SizeAtMost(50)"
                  }
                }
              ]
            }
          },
          {
            "name": "team_override_fields",
            "list": {
              "computed_optional_required": "computed_optional",
              "element_type": {
                "string": {}
              },
              "description": "Telemetry attribute names used to override ownership for data sent with this key. Up to 3 fields are allowed.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/listvalidator"
                      }
                    ],
                    "schema_definition": "listvalidator.SizeBetween(1, 3)"
                  }
                }
              ]
            }
          },
          {
            "name": "id",
            "string": {
              "computed_optional_required": "computed",
              "description": "Unique identifier of the ingestion API key. Generated by Tsuga."
            }
          },
          {
            "name": "key_last_characters",
            "string": {
              "computed_optional_required": "computed",
              "description": "Last visible characters of the secret key. Use this to identify a key without exposing the full secret."
            }
          }
        ]
      }
    },
    {
      "name": "retention_policy",
      "schema": {
        "attributes": [
          {
            "name": "data_source",
            "string": {
              "computed_optional_required": "required",
              "description": "Telemetry signal retained by this policy: logs, metrics, or traces.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.OneOf(\n\"logs\",\n\"metrics\",\n\"traces\",\n)"
                  }
                }
              ]
            }
          },
          {
            "name": "duration_days",
            "int64": {
              "computed_optional_required": "required",
              "description": "Number of days Tsuga should retain matching telemetry. Valid values are 1 through 3650.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/int64validator"
                      }
                    ],
                    "schema_definition": "int64validator.Between(1, 3650)"
                  }
                }
              ]
            }
          },
          {
            "name": "env",
            "string": {
              "computed_optional_required": "computed_optional",
              "description": "Environment tag value this policy applies to. Omit for a policy that is not environment-specific.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.LengthBetween(0, 250)"
                  }
                }
              ]
            }
          },
          {
            "name": "is_enabled",
            "bool": {
              "computed_optional_required": "required",
              "description": "Set to true for the policy to participate in retention resolution."
            }
          },
          {
            "name": "team_id",
            "string": {
              "computed_optional_required": "computed_optional",
              "description": "Team ID this policy applies to. Omit for a policy that is not team-specific.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.LengthBetween(0, 250)"
                  }
                }
              ]
            }
          },
          {
            "name": "id",
            "string": {
              "computed_optional_required": "computed",
              "description": "Unique identifier of the retention policy. Generated by Tsuga."
            }
          }
        ]
      }
    },
    {
      "name": "team",
      "schema": {
        "attributes": [
          {
            "name": "description",
            "string": {
              "computed_optional_required": "computed_optional",
              "description": "Optional team description. Maximum length is 250 characters.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.LengthAtMost(250)"
                  }
                }
              ]
            }
          },
          {
            "name": "name",
            "string": {
              "computed_optional_required": "required",
              "description": "Name to assign to the team",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.LengthBetween(1, 100)"
                  }
                }
              ]
            }
          },
          {
            "name": "tags",
            "list_nested": {
              "computed_optional_required": "computed_optional",
              "nested_object": {
                "attributes": [
                  {
                    "name": "key",
                    "string": {
                      "computed_optional_required": "required",
                      "description": "Tag key to attach to the resource. Maximum length is 128 characters.",
                      "validators": [
                        {
                          "custom": {
                            "imports": [
                              {
                                "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                              }
                            ],
                            "schema_definition": "stringvalidator.LengthAtMost(128)"
                          }
                        }
                      ]
                    }
                  },
                  {
                    "name": "value",
                    "string": {
                      "computed_optional_required": "required",
                      "description": "Tag value to attach to the resource. Maximum length is 256 characters and leading or trailing whitespace is rejected.",
                      "validators": [
                        {
                          "custom": {
                            "imports": [
                              {
                                "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                              }
                            ],
                            "schema_definition": "stringvalidator.LengthAtMost(256)"
                          }
                        },
                        {
                          "custom": {
                            "imports": [
                              {
                                "path": "regexp"
                              },
                              {
                                "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                              }
                            ],
                            "schema_definition": "stringvalidator.RegexMatches(regexp.MustCompile(\"^\\\\S(.*\\\\S)?$\"), \"\")"
                          }
                        }
                      ]
                    }
                  }
                ]
              },
              "description": "Key/value tags to apply to the resource. Up to 50 tags are accepted and tag policies may require specific keys or values.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/listvalidator"
                      }
                    ],
                    "schema_definition": "listvalidator.SizeAtMost(50)"
                  }
                }
              ]
            }
          },
          {
            "name": "visibility",
            "string": {
              "computed_optional_required": "required",
              "description": "`public` makes team-owned resources discoverable according to access controls. `private` restricts discovery to team members and authorized users.",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.OneOf(\n\"public\",\n\"private\",\n)"
                  }
                }
              ]
            }
          },
          {
            "name": "id",
            "string": {
              "computed_optional_required": "computed",
              "description": "Unique identifier of the team. Generated by Tsuga and stable for the team lifetime."
            }
          }
        ]
      }
    }
  ],
  "version": "0.1"
}
